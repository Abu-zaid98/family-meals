# ROOT .env.example (For Vercel Environment Variables Setup)

# --- Frontend Variables (Set in Vercel) ---
VITE_API_URL=https://your-app.vercel.app/api
VITE_FIREBASE_API_KEY=AIza...
VITE_FIREBASE_AUTH_DOMAIN=...firebaseapp.com
VITE_FIREBASE_PROJECT_ID=...
VITE_FIREBASE_STORAGE_BUCKET=...firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=...
VITE_FIREBASE_APP_ID=...
VITE_FIREBASE_MEASUREMENT_ID=...

# --- Backend Variables (Set in Vercel) ---
FRONTEND_URL=https://your-app.vercel.app
FIREBASE_DATABASE_URL=https://...firebaseio.com
FIREBASE_PROJECT_ID=...
FIREBASE_PRIVATE_KEY_ID=...
# On Vercel, the private key should be wrapped in quotes
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...your key...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=...
FIREBASE_CLIENT_ID=...
FIREBASE_STORAGE_BUCKET=...firebasestorage.app
